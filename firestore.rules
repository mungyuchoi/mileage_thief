rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// ⚠️ 주의: 이 파일은 "호텔 캐치" 관련 규칙입니다.
//   프로젝트(mileagethief)의 기존 Firestore 규칙은 콘솔에서 관리되고 있습니다.
//   이 파일을 그대로 `firebase deploy --only firestore:rules` 하면 기존 규칙을
//   덮어씁니다. 반드시 기존 규칙에 아래 match 블록들을 **병합**한 뒤 배포하세요.
//   (또는 콘솔 > Firestore > 규칙 에 아래 블록만 추가)
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 호텔 캐치: 호텔 마스터 =====
    match /hotels/{hotelId} {
      allow read: if request.auth != null;          // 인증 유저만 조회
      allow create, update, delete: if false;        // 집계/생성은 Cloud Function만

      // 퀴즈: 본인 생성/수정/삭제, 집계 필드는 Function이 갱신
      match /quizzes/{quizId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && (resource.data.authorUid == request.auth.uid
              || request.auth.token.admin == true);
      }

      // 꿀팁: 본인 생성/수정/삭제
      match /tips/{tipId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && (resource.data.authorUid == request.auth.uid
              || request.auth.token.admin == true);
      }

      // 기여도: 누구나 읽기(기여왕 표시), 쓰기는 Function만
      match /contributors/{uid} {
        allow read: if true;
        allow write: if false;
      }

      // 리뷰: 누구나 읽기, 본인(doc id == uid)만 작성/수정/삭제
      match /reviews/{uid} {
        allow read: if true;
        allow create, update, delete: if request.auth != null
          && request.auth.uid == uid;
      }
    }

    // ===== 유저 서브컬렉션 =====
    match /users/{uid}/hotelSeen/{hotelId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 정답 보상은 멱등 처리가 필요 → 쓰기는 Function만(클라 직접 쓰기 금지)
    match /users/{uid}/quizSolved/{quizId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /users/{uid}/hotelContrib/{hotelId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    // 꿀팁 좋아요 상태(멱등·작성자 보상) → Function만 write
    match /users/{uid}/tipLikes/{tipId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    // 내 리뷰 미러(본인 모음)
    match /users/{uid}/hotelReviews/{hotelId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/notifications/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 이벤트 보상 클레임(웰컴 보너스 등) — 본인 읽기만, 지급은 Function만(멱등 1회)
    match /users/{uid}/eventClaims/{eventId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 이벤트 설정 문서(금액/on-off/기간) — 누구나 읽기, 쓰기는 콘솔/관리자만
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // 쿠폰 마스터 — 코드 노출 방지를 위해 관리자만 읽기, 생성/수정은 Function만
    match /coupons/{code} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'owner']);
      allow write: if false;
    }
    // 쿠폰 사용 기록 — 본인 읽기만, 지급/기록은 Function만(1인 1회 멱등)
    match /users/{uid}/couponRedemptions/{code} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

  }
}
