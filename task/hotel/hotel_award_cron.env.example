# Copy values into env/hotel_award_cron.env on the Ubuntu mini PC.

FIREBASE_SERVICE_ACCOUNT=/absolute/path/to/firebase-adminsdk.json
PYTHON_BIN=python3
HOTEL_AWARD_ACTOR_UID=task_hotel_award_cron
HOTEL_AWARD_LOG_DIR=/home/milecatch/mileage_thief/logs/hotel_award
HOTEL_AWARD_LOCK_DIR=/tmp
HOTEL_AWARD_DOMAIN_DELAY_SECONDS=3

# Set true to verify cron wiring without Firestore writes.
HOTEL_AWARD_DRY_RUN=false

# Per-cycle safety limits.
HOTEL_AWARD_MASTER_BUILD_LIMIT=100
HOTEL_AWARD_MASTER_COLLECT_LIMIT=100
HOTEL_AWARD_POPULAR_BUILD_LIMIT=80
HOTEL_AWARD_POPULAR_COLLECT_LIMIT=50
HOTEL_AWARD_ALERT_BUILD_LIMIT=80
HOTEL_AWARD_ALERT_COLLECT_LIMIT=40
HOTEL_AWARD_URGENT_BUILD_LIMIT=40
HOTEL_AWARD_URGENT_COLLECT_LIMIT=20
HOTEL_AWARD_BACKFILL_BUILD_LIMIT=60
HOTEL_AWARD_BACKFILL_COLLECT_LIMIT=30
